# ─── Backend (.env in /backend) ────────────────────────
NIMBLE_API_KEY=your_nimble_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── Frontend (.env.local in /frontend) ────────────────
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (replace with your Railway/Render URL):
# NEXT_PUBLIC_API_URL=https://scavenger-work-api.railway.app

# ─── Tower apps ────────────────────────────────────────
# Set via: tower secrets set NIMBLE_API_KEY=...
# tower secrets set OPENAI_API_KEY=...
